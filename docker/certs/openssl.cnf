[req]
default_bits = 2048
prompt = no
default_md = sha256
x509_extensions = v3_req
distinguished_name = dn

[dn]
C = BD
ST = Dhaka
L = Dhaka
O = Video Chat Local
OU = Development
CN = localhost

[v3_req]
subjectAltName = @alt_names
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth

[alt_names]
DNS.1 = localhost
DNS.2 = laravel-nginx
IP.1 = 127.0.0.1
IP.2 = 192.168.0.104
IP.3 = 192.168.50.104
